# DipCoin Perpetual Trading CLI Configuration

# Required: 12-word mnemonic phrase
# Index 0 = main account, index 1+ = vault sub-accounts (via --vault-index)
MNEMONIC=word1 word2 word3 word4

# Network: mainnet or testnet
NETWORK=testnet

# Optional: Default vault index for HD-derived sub-accounts
# DEFAULT_VAULT_INDEX=
