# DipCoin Perpetual Trading CLI Configuration

# Option 1: Sui private key (recommended, supports ED25519/Secp256k1/Secp256r1)
DIPCOIN_PRIVATE_KEY=suiprivkey1...

# Option 2: 12-word mnemonic phrase (derives keypair at m/44'/784'/0'/0'/0')
# DIPCOIN_MNEMONIC=word1 word2 word3 ... word12

# Network: mainnet or testnet
DIPCOIN_NETWORK=testnet
